POSTGRES_USER=smarttender
POSTGRES_PASSWORD=smarttender_pass
POSTGRES_DB=smarttender

DATABASE_URL=postgresql://smarttender:smarttender_pass@smarttender_db:5432/smarttender
REDIS_URL=redis://smarttender_redis:6379/0
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@smarttender.kz

# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ── BIN Verification (stat.gov.kz) ───────────────────────────
EGOV_API_URL=https://stat.gov.kz/api/legal/rest/names/bin
EGOV_API_TIMEOUT=5.0

# ── Stripe Payments ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Goszakupki.kz ────────────────────────────────────────────
GOSZAKUPKI_API_URL=https://goszakupki.kz/api/v1
GOSZAKUPKI_API_KEY=
GOSZAKUPKI_TIMEOUT=5
GOSZAKUPKI_MAX_RETRIES=3

# ── Odoo ERP ─────────────────────────────────────────────────
ODOO_URL=http://localhost:8069
ODOO_DB=smarttender
ODOO_USERNAME=admin
ODOO_PASSWORD=
ODOO_TIMEOUT=10
ODOO_MAX_RETRIES=3

# ── File Storage ─────────────────────────────────────────────
UPLOAD_DIR=uploads
USE_MINIO=false
MINIO_ENDPOINT=smarttender_minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=smarttender-reports

APP_PUBLIC_URL=http://localhost:3000
